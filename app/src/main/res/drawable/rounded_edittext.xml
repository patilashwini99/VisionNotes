<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background color -->
    <solid android:color="#FFFFFF"/>

    <!-- Corner radius -->
    <corners android:radius="25dp"/>

    <!-- Border -->
    <stroke
        android:width="1dp"
        android:color="#0B2CF4"/>

    <!-- Padding inside -->
    <padding
        android:left="15dp"
        android:right="15dp"
        android:top="10dp"
        android:bottom="10dp"/>

</shape>
